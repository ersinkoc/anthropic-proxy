# Copy this file to .env and fill in your real values.

# OpenAI-compatible upstream endpoint.
UPSTREAM_URL=https://integrate.api.nvidia.com/v1/chat/completions

# Your upstream API key.
UPSTREAM_API_KEY=replace-with-your-api-key

# The model you want the proxy to use.
DEFAULT_MODEL=meta/llama-3.1-8b-instruct

# 1 = always replace any incoming Claude/Anthropic model with DEFAULT_MODEL.
# 0 = use MODEL_MAP / fallback logic instead.
FORCE_MODEL=1

# Optional mapping mode example when FORCE_MODEL=0:
# MODEL_MAP={"claude-opus-4-1":"meta/llama-3.1-70b-instruct","claude-sonnet-4":"meta/llama-3.1-8b-instruct"}

# Proxy listen address. Changing this still requires a restart.
LISTEN_ADDR=:8787

# Hot-reloaded per request.
REQUEST_TIMEOUT_SEC=600
DEBUG=0

# Optional: require clients to send this key to your proxy.
# PROXY_CLIENT_KEY=your-proxy-client-key
